# SDK
GENLAYER_RELAY_URL=http://localhost:8000
# For production pinning, set one of:
# GENLAYER_PUBLIC_KEY_PATH=relay_public_key.pem
# GENLAYER_PUBLIC_KEY_PEM="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

# Relay
GENLAYER_MAX_SKEW_SECONDS=300
GENLAYER_WEATHER_PROVIDER=open-meteo
GENLAYER_PRICE_PROVIDER=coingecko
# Optional for CoinGecko higher rate limits:
# COINGECKO_API_KEY=your_api_key_here
# Set one of these for a stable signing identity across restarts:
# GENLAYER_PRIVATE_KEY_PATH=relay_private_key.pem
# GENLAYER_PRIVATE_KEY_PEM="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
